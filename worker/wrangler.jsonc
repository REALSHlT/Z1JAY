{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "z1jay-ai",
  "main": "src/index.js",
  "compatibility_date": "2026-07-01",
  "ai": {
    "binding": "AI"
  },
  "observability": {
    "enabled": true
  },
  // Per-IP rate limiting with exact counters (per-minute + per-day)
  "durable_objects": {
    "bindings": [
      { "name": "IP_LIMITER", "class_name": "IpLimiter" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["IpLimiter"] }
  ]
}
